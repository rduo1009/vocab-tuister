package list

import (
	"github.com/charmbracelet/bubbles/help"
	"github.com/charmbracelet/bubbles/textarea"
)

type Model struct {
	width, height int
	err           error

	textarea textarea.Model
	help     help.Model
	keys     KeyMap
}

func New() *Model {
	return &Model{
		textarea: nil,
		help:     help.New(),
		keys:     DefaultKeyMap,

		err: nil,
	}
}
